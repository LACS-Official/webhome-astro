---
interface Props {
  images?: Array<{ src: string; alt: string; title?: string }>;
}

const {
  images = [
    {
      src: '/images/platforms/mt.svg',
      alt: '2023年小米社区开聊了玩机达人贡献奖',
      title: '2023年小米社区开聊了玩机达人贡献奖',
    },
    {
      src: '/images/platforms/csdn.svg',
      alt: 'CSDN连续多月铁岭市博主周榜第一名',
      title: 'CSDN连续多月铁岭市博主周榜第一名',
    },
    { src: '/images/platforms/blibli.svg', alt: 'B站一万粉荣誉', title: 'B站一万粉荣誉' },
  ],
} = Astro.props;
---

<div class="honor-grid-container relative">
  <h3 class="text-xl md:text-3xl font-black text-slate-900 dark:text-white text-center mb-6 md:mb-10 tracking-tight">荣誉展示</h3>

  <div class="honor-grid">
    {
      images.map((img) => (
        <div class="honor-card group">
          <div class="image-container">
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
          {img.title && <span class="honor-title">{img.title}</span>}
        </div>
      ))
    }
  </div>
</div>

<style>
  .honor-grid-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }

  .honor-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .honor-card {
    position: relative;
    background-color: transparent;
    border: 1px solid rgba(0, 0, 0, 0.05); /* very light border */
    border-radius: 1.5rem;
    padding: 1.5rem 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    overflow: hidden;
    transition: transform 0.3s ease;
  }
  
  .honor-card:hover {
    transform: translateY(-4px);
  }

  .image-container {
    width: 100%;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .honor-card img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.1));
    transition: all 0.6s ease;
  }

  .honor-title {
    font-size: 0.75rem;
    font-weight: 800;
    color: #0f172a;
    text-align: center;
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (prefers-color-scheme: dark) {
    .honor-card {
      border-color: rgba(255, 255, 255, 0.05);
    }
    .honor-card:hover {
      background-color: rgba(255, 255, 255, 0.02);
    }
    .honor-title {
      color: #f8fafc;
    }
  }

  @media (max-width: 768px) {
    .honor-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
    .honor-card {
      padding: 1rem 0.5rem;
      border-radius: 1.5rem;
      gap: 0.75rem;
    }
    .image-container {
      height: 50px;
    }
    .honor-title {
      font-size: 0.65rem;
    }
  }
</style>
