---
import type { Sites as Props } from '~/types';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { Icon } from 'astro-icon/components';
const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  sites = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

const getBgColorClass = (bgColor: string) => {
  const colorMap = {
    primary: 'from-primary to-primary-600',
    secondary: 'from-secondary to-secondary-600',
    accent: 'from-accent to-yellow-500',
    dark: 'from-gray-800 to-gray-900',
  };
  return colorMap[bgColor] || 'from-primary to-primary-600';
};
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 md:gap-8">
    {
      sites.map((site) => (

          <a href={site.link} target="_blank" rel="noopener noreferrer" class="group flex h-full">
            <div 
              class="relative flex flex-col w-full h-full p-5 md:p-6 transition-all duration-300 overflow-hidden bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 rounded-2xl group hover:-translate-y-1 hover:shadow-sm"
            >
              <div class="flex items-center justify-between mb-5 relative z-10">
                <div
                  class={`flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-xl text-white shadow-sm relative overflow-hidden group-hover:scale-105 transition-all duration-300 shrink-0 before:absolute before:inset-0 before:bg-gradient-to-br before:${getBgColorClass(site.bgColor)} before:opacity-100 after:absolute after:inset-0 after:bg-white/10 after:opacity-0 group-hover:after:opacity-100 after:transition-opacity`}
                >
                  <div class="relative z-10 p-1 md:p-1.5 w-full h-full">
                    {site.logo ? (
                      <img src={site.logo} alt={site.name} class="w-full h-full rounded-md object-contain" />
                    ) : (
                      <Icon
                        name={
                          site.iconContent && /^[a-zA-Z0-9-]+$/.test(site.iconContent.replace('fa-', ''))
                            ? `tabler:${site.iconContent.replace('fa-', '')}`
                            : 'tabler:world'
                        }
                        class="w-5 h-5 md:w-7 md:h-7 text-white"
                      />
                    )}
                  </div>
                </div>
                <div class="text-slate-400 dark:text-slate-500 group-hover:text-slate-900 dark:group-hover:text-white transition-colors transform group-hover:translate-x-0.5 duration-300">
                  <Icon name="tabler:arrow-up-right" class="w-5 h-5 md:w-6 md:h-6" />
                </div>
              </div>

              <div class="relative z-10 flex-grow flex flex-col mt-2">
                <div class="overflow-x-auto no-scrollbar whitespace-nowrap md:whitespace-normal mask-fade-right">
                  <h3 class="text-base md:text-lg font-bold text-slate-900 dark:text-white mb-1 tracking-tight">
                    {site.name}
                  </h3>
                </div>

                <div class="h-12 md:h-16 overflow-y-auto no-scrollbar w-full mt-1 border-t border-slate-100 dark:border-slate-800/50 pt-3">
                  <p class="text-slate-500 dark:text-slate-400 text-xs md:text-sm leading-relaxed font-normal">
                    {site.description}
                  </p>
                </div>
              </div>
            </div>
          </a>

      ))
    }
  </div>
</WidgetWrapper>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .mask-fade-right {
    -webkit-mask-image: linear-gradient(to right, black calc(100% - 20px), transparent 100%);
    mask-image: linear-gradient(to right, black calc(100% - 20px), transparent 100%);
  }
</style>
