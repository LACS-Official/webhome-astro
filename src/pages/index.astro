---
// 启用 SSR - 每次请求时动态渲染此页面
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';

import Content from '~/components/widgets/Content.astro';
import Projects from '~/components/widgets/Projects.astro';
import Sites from '~/components/widgets/Sites.astro';
import Modal from '~/components/Modal.astro';
import HonorCarousel from '~/components/widgets/HonorCarousel.astro';
import SpotlightCard from '~/components/reactbits/SpotlightCard';
import type { Project, Site, ApiSiteResponse } from '~/types';

// 导入图片

import { fetchWithRetry } from '~/utils/utils';

// API 配置
const API_BASE_URL = 'https://api-g.lacs.cc/api';

// 获取项目数据
let projectsData: Project[] = [];
try {
  const projectsResponse = await fetchWithRetry(`${API_BASE_URL}/info-management/projects`);
  if (projectsResponse && projectsResponse.ok) {
    const projectsResult = await projectsResponse.json();
    if (projectsResult.success && projectsResult.data) {
      projectsData = projectsResult.data;
      console.log('成功获取项目数据，共', projectsData.length, '条记录');
    }
  }
} catch (error) {
  console.error('获取项目数据失败:', error instanceof Error ? error.message : error);
}

// 获取站点数据
let sitesData: Site[] = [];
try {
  const sitesResponse = await fetchWithRetry(`${API_BASE_URL}/info-management/sub-sites`);
  if (sitesResponse && sitesResponse.ok) {
    const sitesResult = await sitesResponse.json();
    if (sitesResult.success && sitesResult.data && Array.isArray(sitesResult.data)) {
      // 过滤只展示 `isShowInAboutUs` 为 true 的站点
      const visibleSites = sitesResult.data.filter((site: ApiSiteResponse) => site.isShowInAboutUs === true);
      
      sitesData = visibleSites.map((site: ApiSiteResponse) => ({
        id: site.id,
        name: site.name,
        description: site.description || `访问 ${site.name}`,
        link: site.domain.startsWith('http') ? site.domain : `https://${site.domain}`,
        logo: site.logo || '',
        iconContent: site.logo ? '' : site.name.charAt(0), // 如果没有 logo，使用首字母
        bgColor: site.category || '#3B82F6', // 默认蓝色
        analyticsEvent: `visit_${site.name.toLowerCase().replace(/\s+/g, '_')}`,
        category: site.category || '网站',
      }));
      console.log('成功获取站点数据，共', sitesData.length, '条显示记录');
    }
  }
} catch (error) {
  console.error('获取站点数据失败:', error instanceof Error ? error.message : error);
}

const metadata = {
  title: '领创工作室 - 数码科技与创意内容平台',
  ignoreTitleTemplate: true,
};

// 快捷跳转链接配置
const quickLinks = [
  {
    title: '联系我们',
    description: '商务合作与咨询',
    href: '/contact',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    colorClass: 'blue',
    hoverColorClass: 'primary',
  },
  {
    title: '媒体平台',
    description: 'B站、CSDN等平台',
    href: '/contact#media-platforms',
    icon: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z',
    colorClass: 'purple',
    hoverColorClass: 'purple-600',
  },
  {
    title: '社区群聊',
    description: '加入我们的社区',
    href: '/contact#qun-group',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    colorClass: 'green',
    hoverColorClass: 'green-600',
  },
  {
    title: '远程刷机',
    description: '专业刷机服务',
    href: '/ycsj',
    icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z',
    colorClass: 'orange',
    hoverColorClass: 'orange-600',
  },
  {
    title: '我要打赏',
    description: '支持我们的持续创作',
    href: '/donate',
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
    colorClass: 'red',
    hoverColorClass: 'red-600',
  },
];
---

<Layout metadata={metadata}>
  <!-- Schema.org 结构化数据 -->
  <script type="application/ld+json" is:inline slot="head">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "领创工作室",
      "alternateName": "Lead And Create Studio (LACS)",
      "url": "https://lacs.cc",
      "logo": "https://img-g.lacs.cc/file/lacswebsite/1770644464021_工作室背景_baizi.webp",
      "description": "领创工作室是一个专注于数码科技与创意内容领域的创新团队，提供移动设备工具开发与技术解决方案。",
      "sameAs": ["https://space.bilibili.com/393226245", "https://blog.csdn.net/qq_43331088"],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "https://lacs.cc/contact"
      }
    }
  </script>
  <!-- Hero Widget ******************* -->

  <section
    class="hero-section relative min-h-[70vh] lg:h-screen w-full not-prose overflow-hidden flex items-center justify-center bg-white dark:bg-[#0a0a0a] lg:bg-transparent"
  >
    <!-- 视频背景（大屏幕） -->
    <video
      autoplay
      muted
      playsinline
      loop
      poster="https://img-g.lacs.cc/file/lacswebsite/1770644464021_工作室背景_baizi.webp"
      class="hidden lg:block absolute inset-0 w-full h-full object-cover"
    >
      <source src="/videos/lacs_mg_noend.webm" type="video/webm" />
    </video>

    <!-- 视频遮罩层 (大屏) -->
    <div class="hidden lg:block absolute inset-0 bg-slate-900/60"></div>

    <!-- 主要内容 -->
    <div class="relative w-full px-6 sm:px-8 lg:px-12 z-10 py-16 lg:py-0 mt-8 lg:mt-0">
      <div
        class="text-center max-w-3xl mx-auto flex flex-col items-center justify-center"
      >
        <!-- 标语图片 -->
        <div class="mb-8 lg:mb-12">
          <img
            src="https://img-g.lacs.cc/file/lacswebsite/1770644464021_工作室背景_baizi.webp"
            alt="领创工作室"
            class="h-20 sm:h-24 md:h-32 lg:h-44 w-auto mx-auto object-contain drop-shadow-md lg:drop-shadow-2xl"
            loading="eager"
          />
        </div>

        <!-- 主标题 -->
        <h1
          class="text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-5 text-slate-900 dark:text-white lg:text-white"
        >
          专注于数码科技<br class="hidden sm:block lg:hidden" />与创意内容
        </h1>

        <!-- 副标题 -->
        <p
          class="text-[1.05rem] sm:text-lg lg:text-xl text-slate-500 dark:text-slate-400 lg:text-slate-200 mb-10 max-w-2xl mx-auto font-normal leading-relaxed"
        >
          致力于移动设备工具开发与数字内容创作的创新团队，<br class="hidden md:block" />
          为您提供高质量的软件使用体验。
        </p>

        <!-- 行动召唤按钮 -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center w-full sm:w-auto">
          <a
            href="#projects"
            class="bg-slate-900 text-white dark:bg-white dark:text-slate-900 lg:bg-white lg:text-slate-900 px-8 py-3.5 sm:px-10 sm:py-4 text-base sm:text-lg font-medium rounded-full transition-transform hover:scale-[1.02] active:scale-95 flex items-center justify-center w-full sm:w-auto"
          >
            查看项目
          </a>
          <a
            href="#sites"
            class="bg-slate-100 text-slate-900 dark:bg-slate-800 dark:text-white lg:bg-white/10 lg:text-white lg:backdrop-blur-md lg:border lg:border-white/10 px-8 py-3.5 sm:px-10 sm:py-4 text-base sm:text-lg font-medium rounded-full transition-transform hover:scale-[1.02] active:scale-95 flex items-center justify-center w-full sm:w-auto"
          >
            探索分站
          </a>
        </div>
      </div>
    </div>

    <!-- 滚动提示 (优化样式) -->
    <div
      class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 hover:opacity-80 transition-opacity"
    >
      <div class="w-5 h-8 border-2 border-slate-400 dark:border-slate-500 rounded-full flex justify-center p-1">
        <div class="w-1 h-1.5 bg-slate-400 dark:bg-slate-500 rounded-full animate-wheel"></div>
      </div>
    </div>
  </section>

  <!-- Projects Widget ****************** -->

  <Projects
    id="projects"
    title="我们的项目作品"
    subtitle="探索领创工作室开发的各类软件工具和创意项目"
    tagline="项目展示"
    projects={projectsData}
  >
    <Fragment slot="tagline">
      <span class="text-blue-500 font-bold tracking-widest uppercase">项目展示</span>
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-slate-800"></div>
    </Fragment>
  </Projects>

  <!-- Sites Widget ****************** -->

  <Sites
    id="sites"
    title="我们的分站平台"
    subtitle="探索领创工作室旗下的各个专业平台"
    tagline="分站导航"
    sites={sitesData}
  >
    <Fragment slot="tagline">
      <span class="text-blue-500 font-bold tracking-widest uppercase">分站导航</span>
    </Fragment>
  </Sites>

  <!-- About Widget ******************* -->

  <Content id="about" title="关于领创工作室" subtitle="我们是一个专注于数码科技领域的创新团队" tagline="关于我们">
    <Fragment slot="tagline">
      <span class="text-blue-500 font-bold tracking-widest uppercase">关于我们</span>
    </Fragment>
    <Fragment slot="content">
      <div class="mb-6 md:mb-12">
        <p class="text-base md:text-lg dark:text-slate-400 mb-6 md:mb-8">
          领创工作室成立于2020年，致力于为用户提供高质量的软件工具和技术解决方案。专注于移动设备工具开发、软件开发和数字内容创作。
        </p>

        <!-- Bento 历程展示 (替代旧时间线) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 relative z-10">
          <div
            class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-px bg-gradient-to-r from-transparent via-blue-200/50 dark:via-blue-800/20 to-transparent hidden md:block select-none pointer-events-none"
          >
          </div>

          <!-- 2020-2021 -->
          <SpotlightCard client:visible className="p-4 md:p-6 glass-panel">
            <div
              class="text-2xl md:text-4xl font-black text-blue-600/10 dark:text-slate-700/30 absolute top-2 right-2 md:top-4 md:right-4 select-none"
            >
              2020/21
            </div>
            <h4 class="font-bold text-lg md:text-xl text-blue-600 dark:text-blue-400 mb-2 flex items-center">
              <span class="w-2 h-2 bg-blue-600 rounded-full mr-3 animate-pulse"></span> 起步与探索
            </h4>
            <p class="text-sm dark:text-slate-400 leading-relaxed">
              工作室正式成立。在这两年间，我们从安卓开发起步，并为仙龙阁、智简云等多个品牌提供专业的 Logo 与视觉设计。
            </p>
          </SpotlightCard>

          <!-- 2022-2023 -->
          <SpotlightCard client:visible className="p-4 md:p-6 md:translate-y-8 glass-panel">
            <div
              class="text-2xl md:text-4xl font-black text-blue-600/10 dark:text-slate-700/30 absolute top-2 right-2 md:top-4 md:right-4 select-none"
            >
              2022/23
            </div>
            <h4 class="font-bold text-lg md:text-xl text-blue-600 dark:text-blue-400 mb-2 flex items-center">
              <span class="w-2 h-2 bg-blue-600 rounded-full mr-3 animate-pulse"></span> 锋芒毕露
            </h4>
            <p class="text-sm dark:text-slate-400 leading-relaxed">
              深耕安卓玩机领域，发布多款面具模块与一键 Root 工具箱（用户破千），开启远程刷机服务，服务客户上百位。
            </p>
          </SpotlightCard>

          <!-- 2024-2025 -->
          <SpotlightCard client:visible className="p-4 md:p-6 glass-panel">
            <div
              class="text-2xl md:text-4xl font-black text-blue-600/10 dark:text-slate-700/30 absolute top-2 right-2 md:top-4 md:right-4 select-none"
            >
              2024/25
            </div>
            <h4 class="font-bold text-lg md:text-xl text-blue-600 dark:text-blue-400 mb-2 flex items-center">
              <span class="w-2 h-2 bg-blue-600 rounded-full mr-3 animate-pulse"></span> 跨越式发展
            </h4>
            <p class="text-sm dark:text-slate-400 leading-relaxed">
              **关键年**。澎湃解锁工具箱用户破万，玩机管家发布（22000+设备管理）。B站粉丝突破 1.5W，Csdn
              粉丝破千，哈基创小程序用户突破 2000。
            </p>
          </SpotlightCard>

          <!-- 未来展望 -->
          <SpotlightCard
            client:visible
            className="p-4 md:p-6 md:translate-y-8 glass-panel border-blue-200/30 dark:border-blue-700/20"
          >
            <div
              class="text-2xl md:text-4xl font-black text-blue-600/10 dark:text-blue-500/10 absolute top-2 right-2 md:top-4 md:right-4 select-none"
            >
              2026+
            </div>
            <h4 class="font-bold text-lg md:text-xl text-blue-600 dark:text-blue-400 mb-2 flex items-center">
              <span class="w-2 h-2 bg-blue-600 rounded-full mr-3 animate-pulse"></span> 持续进化
            </h4>
            <p class="text-sm dark:text-slate-400 leading-relaxed italic">
              持续创新，探索更多可能性。我们将继续深耕玩机领域与内容创作，为用户带来更多极致的工具与体验。
            </p>
          </SpotlightCard>
        </div>
      </div>
    </Fragment>
    <Fragment slot="callToAction">
      <a href="/contact" class="btn-primary">联系我们</a>
    </Fragment>
    <Fragment slot="image">
      <div class="space-y-6 p-6">
        <HonorCarousel />

        <h3 class="text-xl md:text-2xl font-bold text-slate-800 dark:text-white text-center">功能跳转</h3>

        <div class="grid grid-cols-2 lg:grid-cols-1 gap-2 md:gap-4">
          {
            quickLinks.map((link) => (
              <SpotlightCard
                client:visible
                className="p-0 rounded-2xl overflow-hidden glass-panel shadow-[0_1px_2px_rgba(0,0,0,0.05),0_8px_16px_-4px_rgba(0,0,0,0.01)]  transition-all duration-300"
              >
                <a href={link.href} class="flex items-center gap-3 p-3 md:p-5 bg-white/40 dark:bg-transparent group h-full">
                  <div
                    class={`w-12 h-12 md:w-14 md:h-14 bg-${link.colorClass}-50 dark:bg-${link.colorClass}-900/10 rounded-xl md:rounded-2xl flex items-center justify-center `}
                  >
                    <svg
                      class={`w-6 h-6 md:w-7 md:h-7 text-${link.colorClass}-600 dark:text-${link.colorClass}-400 `}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={link.icon} />
                    </svg>
                  </div>
                  <div class="flex-1">
                    <h4 class="font-bold text-slate-800 dark:text-slate-100 text-xs md:text-base">{link.title}</h4>
                    <p class="hidden md:block text-xs text-slate-500 dark:text-slate-400">{link.description}</p>
                  </div>
                  <div class={`hidden md:flex p-2 rounded-full bg-slate-50 dark:bg-slate-800/50 group-hover:bg-${link.hoverColorClass} transition-colors`}>
                    <svg
                      class="w-4 h-4 text-slate-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </a>
              </SpotlightCard>
            ))
          }
        </div>
      </div>
    </Fragment>
  </Content>
</Layout>

<style is:global>
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-15px) rotate(1deg);
    }
  }

  @keyframes wheel {
    to {
      opacity: 0;
      transform: translateY(15px);
    }
  }

  .animate-float {
    animation: float 5s ease-in-out infinite;
  }

  .animate-wheel {
    animation: wheel 2s infinite;
  }

  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
</style>

<!-- 模态框 -->
<Modal />
