---
// 启用预渲染 - 静态生成此页面
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import Modal from '~/components/Modal.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: '支持我们 - 领创工作室',
  description: '支持领创工作室的发展，您的捐赠将帮助我们提供更好的服务和开发更多优质项目。多种捐赠方式，感谢您的支持！',
  keywords: '捐赠,支持,赞助,领创工作室,开源项目',
};

// 捐赠用途
const donationUsage = [
  {
    title: '服务器维护',
    description: '维护网站服务器、域名续费、CDN加速等基础设施费用。',
    icon: 'tabler:server',
    percentage: '40%',
  },
  {
    title: '项目开发',
    description: '投入新项目的研发，购买开发工具和软件许可证。',
    icon: 'tabler:code',
    percentage: '35%',
  },
  {
    title: '技术学习',
    description: '团队成员技术培训、购买学习资料和参加技术会议。',
    icon: 'tabler:book',
    percentage: '15%',
  },
  {
    title: '社区建设',
    description: '维护技术社区、举办活动、奖励贡献者等。',
    icon: 'tabler:users',
    percentage: '10%',
  },
];

// 支持者权益
const supporterBenefits = [
  {
    title: '专属标识',
    description: '在我们的项目和网站中展示支持者专属标识。',
    icon: 'tabler:badge',
  },
  {
    title: '优先支持',
    description: '享受技术支持和服务的优先处理权。',
    icon: 'tabler:star',
  },
];
---

<Layout metadata={metadata}>
  <CustomStyles />

  <!-- 二维码展示 -->
  <section
    class="py-12 md:py-20 relative overflow-hidden bg-slate-50/50 dark:bg-slate-950/20 border-b border-slate-100 dark:border-slate-800/50"
    id="donation-methods"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl font-black mb-3 tracking-tight text-slate-900 dark:text-white">扫码支持</h1>
        <p class="text-sm text-slate-600 dark:text-slate-400 mb-8 max-w-md mx-auto">
          请使用微信或支付宝扫码支持我们，或长按保存二维码。
          <span class="text-xs text-slate-400 dark:text-slate-500 mt-1 block">（支持信用卡、花呗等支付通道）</span>
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
          <!-- 微信卡片 -->
          <div
            class="group relative flex flex-col items-center p-5 md:p-6 bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 hover:border-primary/50 dark:hover:border-primary/50 rounded-2xl hover:shadow-[0_12px_30px_rgba(28,100,242,0.08)] dark:hover:shadow-[0_12px_30px_rgba(1,97,239,0.15)] transition-all duration-300 overflow-hidden text-center h-full"
          >
            <div
              class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-full blur-2xl -mr-8 -mt-8 transition-transform group-hover:scale-150 pointer-events-none"
            >
            </div>

            <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100 mb-4 z-10">微信支付</h3>

            <div
              class="relative w-44 h-44 md:w-48 md:h-48 mx-auto mb-4 p-2 bg-white rounded-2xl border border-slate-200 dark:border-slate-800 transition-all duration-300 cursor-pointer qr-code z-10"
              data-image="/images/qrcodes/wx.webp"
              data-title="微信支付"
              data-description="扫码完成捐赠"
            >
              <img src="/images/qrcodes/wx.webp" alt="微信二维码" class="w-full h-full object-contain rounded-xl" />
            </div>

            <a
              href="/images/qrcodes/wx.webp"
              download="wx-qrcode.webp"
              class="z-10 mt-auto px-4 py-1.5 bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700/80 text-slate-700 dark:text-slate-300 text-xs font-semibold rounded-lg border border-slate-200 dark:border-slate-700/50 transition-colors cursor-pointer w-full flex items-center justify-center gap-1.5"
            >
              <Icon name="tabler:download" class="w-3.5 h-3.5" />
              下载二维码
            </a>
          </div>

          <!-- 支付宝卡片 -->
          <div
            class="group relative flex flex-col items-center p-5 md:p-6 bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 hover:border-primary/50 dark:hover:border-primary/50 rounded-2xl hover:shadow-[0_12px_30px_rgba(28,100,242,0.08)] dark:hover:shadow-[0_12px_30px_rgba(1,97,239,0.15)] transition-all duration-300 overflow-hidden text-center h-full"
          >
            <div
              class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-full blur-2xl -mr-8 -mt-8 transition-transform group-hover:scale-150 pointer-events-none"
            >
            </div>

            <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100 mb-4 z-10">支付宝支付</h3>

            <div
              class="relative w-44 h-44 md:w-48 md:h-48 mx-auto mb-4 p-2 bg-white rounded-2xl border border-slate-200 dark:border-slate-800 transition-all duration-300 cursor-pointer qr-code z-10"
              data-image="/images/qrcodes/zfb.webp"
              data-title="支付宝"
              data-description="扫码完成捐赠"
            >
              <img src="/images/qrcodes/zfb.webp" alt="支付宝二维码" class="w-full h-full object-contain rounded-xl" />
            </div>

            <a
              href="/images/qrcodes/zfb.webp"
              download="zfb-qrcode.webp"
              class="z-10 mt-auto px-4 py-1.5 bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700/80 text-slate-700 dark:text-slate-300 text-xs font-semibold rounded-lg border border-slate-200 dark:border-slate-700/50 transition-colors cursor-pointer w-full flex items-center justify-center gap-1.5"
            >
              <Icon name="tabler:download" class="w-3.5 h-3.5" />
              下载二维码
            </a>
          </div>
        </div>

        <div
          class="mt-8 text-center text-xs text-slate-500 dark:text-slate-400 max-w-md mx-auto leading-relaxed border-t border-slate-100 dark:border-slate-800/80 pt-4"
        >
          温馨提示：支付完成后请截图保存凭证，并前往 <a
            href="/contact"
            class="text-primary hover:underline font-semibold">联系我们</a
          > 页面，添加客服登记您的支持者昵称，以便展示在下方支持者名单中并获取专属权益。
        </div>
      </div>
    </div>
  </section>

  <!-- 支持者名单 -->
  <section class="py-16 md:py-20 bg-white dark:bg-[#0a0a0a]" id="supporters-section">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-black mb-2 text-slate-900 dark:text-white">感谢您的支持</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-10 max-w-lg mx-auto">
          以下朋友对领创工作室提供了宝贵支持，是你们让我们的开源开发更有温度。
        </p>

        <!-- 统计面板 -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8 text-left">
          <!-- 累计人数 -->
          <div class="bg-slate-50 dark:bg-slate-900/40 p-5 rounded-2xl border border-slate-100 dark:border-slate-800">
            <p class="text-xs text-slate-500 dark:text-slate-400 font-medium uppercase tracking-wider mb-1">
              累计支持人数
            </p>
            <h3 class="text-2xl font-black text-primary" id="stat-count">0 人</h3>
          </div>
          <div
            class="bg-slate-50 dark:bg-slate-900/40 p-5 rounded-2xl border border-slate-100 dark:border-slate-800 sm:col-span-1"
          >
            <p class="text-xs text-slate-500 dark:text-slate-400 font-medium uppercase tracking-wider mb-1">开源动力</p>
            <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 truncate">
              每一份支持，都是前行的星光 ✨
            </p>
          </div>
        </div>

        <!-- 筛选与控制栏 -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6 text-left">
          <!-- 排序选项 -->
          <div class="flex items-center gap-2 w-full sm:w-auto">
            <span class="text-xs font-semibold text-slate-500">排序：</span>
            <select
              id="sort-select"
              class="text-xs font-semibold bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-1 focus:ring-primary cursor-pointer"
            >
              <option value="newest">最新捐赠</option>
              <option value="oldest">最早捐赠</option>
            </select>
          </div>
          <!-- 搜索框 -->
          <div class="relative w-full sm:w-64">
            <input
              type="text"
              id="search-input"
              placeholder="搜索支持者昵称..."
              class="w-full text-xs font-semibold bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 rounded-lg pl-8 pr-4 py-1.5 focus:outline-none focus:ring-1 focus:ring-primary"
            />
            <Icon
              name="tabler:search"
              class="w-4 h-4 text-slate-400 absolute left-2.5 top-1/2 transform -translate-y-1/2"
            />
          </div>
        </div>

        <div class="mt-4">
          <!-- 名单网格 -->
          <div
            id="supporters-list-grid"
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 min-h-[100px] text-left"
          >
            <!-- JS 动态渲染 -->
          </div>

          <!-- 加载更多 -->
          <div id="load-more-container" class="mt-8 text-center hidden">
            <button
              id="load-more-btn"
              class="px-6 py-2 bg-slate-100 hover:bg-slate-200 dark:bg-slate-900 dark:hover:bg-slate-800/80 text-slate-700 dark:text-slate-300 text-xs font-bold rounded-xl border border-slate-200 dark:border-slate-800 transition-all cursor-pointer"
            >
              加载更多支持者
            </button>
          </div>

          <div
            class="mt-8 p-4 bg-slate-50 dark:bg-slate-900/40 border border-slate-100 dark:border-slate-800 rounded-2xl"
          >
            <p class="text-xs text-slate-500 dark:text-slate-400 font-medium flex items-center justify-center">
              <Icon name="tabler:info-circle" class="w-4 h-4 mr-2 text-slate-400" />
              支持者名单一般情况在每月月末或月初更新，若未及时更新欢迎大家联系我们
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    function escapeHtml(str: string) {
      if (!str) return '';
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    async function initDonorsList() {
      const gridEl = document.getElementById('supporters-list-grid');
      const loadMoreContainer = document.getElementById('load-more-container');
      const loadMoreBtn = document.getElementById('load-more-btn');
      const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
      const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
      const statCount = document.getElementById('stat-count');
      const statAmount = document.getElementById('stat-amount');

      if (!gridEl) return;

      // 临时展示 Loading 态
      gridEl.innerHTML = `
        <div class="col-span-full text-center py-12 text-slate-500 dark:text-slate-400 text-sm flex flex-col items-center justify-center gap-3">
          <svg class="animate-spin h-6 w-6 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          正在安全加载支持者名单...
        </div>
      `;

      interface Donor {
        name: string;
        amount: string | number;
        message: string;
        donationDate: string;
      }

      let donors: Donor[] = [];
      let currentPage = 1;
      const itemsPerPage = 9;
      let searchQuery = '';
      let currentSort = 'newest';

      const updateStats = () => {
        if (statCount) statCount.textContent = `${donors.length} 人`;
        if (statAmount) {
          const total = donors.reduce((sum, d: Donor) => sum + (Number(d.amount) || 0), 0);
          statAmount.textContent = `￥${total.toFixed(2)}`;
        }
      };

      const renderList = () => {
        const filtered = donors.filter((d) => {
          const name = d.name || '';
          const message = d.message || '';
          const nameMatch = name.toLowerCase().includes(searchQuery.toLowerCase());
          const msgMatch = message.toLowerCase().includes(searchQuery.toLowerCase());
          return nameMatch || msgMatch;
        });

        if (currentSort === 'newest') {
          filtered.sort((a, b) => new Date(b.donationDate).getTime() - new Date(a.donationDate).getTime());
        } else if (currentSort === 'oldest') {
          filtered.sort((a, b) => new Date(a.donationDate).getTime() - new Date(b.donationDate).getTime());
        }

        const totalItems = filtered.length;
        const paginated = filtered.slice(0, currentPage * itemsPerPage);

        if (paginated.length === 0) {
          gridEl.innerHTML = `
            <div class="col-span-full text-center py-8 text-slate-500 dark:text-slate-400 text-sm">
              没有找到匹配的支持者
            </div>
          `;
          if (loadMoreContainer) loadMoreContainer.classList.add('hidden');
          return;
        }

        gridEl.innerHTML = paginated
          .map((supporter) => {
            const rawName = supporter.name
              ? supporter.name === '**'
                ? '匿名支持者 (**)'
                : supporter.name
              : '匿名支持者';
            const displayName = escapeHtml(rawName);
            const amountBadge = supporter.amount
              ? `<span class="text-xs font-bold text-primary bg-primary/10 dark:bg-primary/20 px-2 py-0.5 rounded-md">￥${Number(supporter.amount).toFixed(2)}</span>`
              : '';
            const messageHtml = supporter.message
              ? `<p class="text-xs text-slate-500 dark:text-slate-400 italic bg-slate-50/50 dark:bg-slate-800/30 p-2.5 rounded-xl border border-slate-100 dark:border-slate-800 mt-3 select-none">“ ${escapeHtml(supporter.message)} ”</p>`
              : '';
            const formattedDate = escapeHtml(supporter.donationDate);

            return `
            <div class="group p-5 bg-white dark:bg-slate-900/60 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-[0_12px_30px_rgba(0,0,0,0.04)] hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between relative overflow-hidden">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <p class="font-bold text-slate-800 dark:text-slate-100">${displayName}</p>
                  ${amountBadge}
                </div>
                ${messageHtml}
              </div>
              
              <div class="flex items-center justify-between mt-4 text-[11px] text-slate-500 dark:text-slate-400 font-medium z-10 border-t border-slate-100 dark:border-slate-800/60 pt-3">
                <span>捐赠日期: ${formattedDate}</span>
                <span class="text-[10px] font-bold text-primary dark:text-blue-400 uppercase tracking-widest bg-primary/5 dark:bg-blue-950/30 px-2.5 py-0.5 rounded-full">
                  支持者
                </span>
              </div>
            </div>
          `;
          })
          .join('');

        if (currentPage * itemsPerPage < totalItems) {
          if (loadMoreContainer) loadMoreContainer.classList.remove('hidden');
        } else {
          if (loadMoreContainer) loadMoreContainer.classList.add('hidden');
        }
      };

      if (loadMoreBtn) {
        const newBtn = loadMoreBtn.cloneNode(true);
        if (loadMoreBtn.parentNode) {
          loadMoreBtn.parentNode.replaceChild(newBtn, loadMoreBtn);
        }
        newBtn.addEventListener('click', () => {
          currentPage++;
          renderList();
        });
      }

      if (searchInput) {
        const newSearchInput = searchInput.cloneNode(true) as HTMLInputElement;
        if (searchInput.parentNode) {
          searchInput.parentNode.replaceChild(newSearchInput, searchInput);
        }
        newSearchInput.addEventListener('input', (e) => {
          searchQuery = (e.target as HTMLInputElement).value;
          currentPage = 1;
          renderList();
        });
      }

      if (sortSelect) {
        const newSortSelect = sortSelect.cloneNode(true) as HTMLSelectElement;
        if (sortSelect.parentNode) {
          sortSelect.parentNode.replaceChild(newSortSelect, sortSelect);
        }
        newSortSelect.addEventListener('change', (e) => {
          currentSort = (e.target as HTMLSelectElement).value;
          currentPage = 1;
          renderList();
        });
      }

      // 尝试从会话级缓存读取数据
      const cacheKey = 'lacs_donors_data';
      const cachedData = sessionStorage.getItem(cacheKey);
      if (cachedData) {
        try {
          donors = JSON.parse(cachedData);
        } catch (e) {
          console.error('解析缓存数据失败:', e);
        }
      }

      if (donors.length > 0) {
        updateStats();
        renderList();
      } else {
        try {
          const response = await fetch('https://api-g.lacs.cc/api/donors');
          if (response && response.ok) {
            const result = await response.json();
            if (result.success && result.data) {
              donors = result.data;
              sessionStorage.setItem(cacheKey, JSON.stringify(donors));
            }
          }
        } catch (error) {
          console.error('获取捐赠数据失败:', error);
          gridEl.innerHTML = `
            <div class="col-span-full text-center py-8 text-red-500 dark:text-red-400 text-sm">
              获取支持者数据失败，请稍后刷新重试
            </div>
          `;
          return;
        }
        updateStats();
        renderList();
      }
    }

    document.addEventListener('astro:page-load', initDonorsList);
  </script>

  <!-- 资金用途 -->
  <section
    class="py-16 md:py-20 bg-slate-50/50 dark:bg-slate-900/20 border-y border-slate-100 dark:border-slate-800/80"
    id="usage"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-base text-primary dark:text-blue-200 font-bold tracking-wide uppercase">资金用途</p>
          <h2 class="text-3xl md:text-4xl font-black tracking-tight text-slate-900 dark:text-white mt-1">
            资金使用透明化
          </h2>
          <p class="text-slate-500 dark:text-slate-400 mt-3 text-sm md:text-base">
            您的每一分支持都将直接用于以下基础设施与研发投入
          </p>
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center bg-white dark:bg-slate-900/60 p-6 md:p-8 rounded-3xl border border-slate-200/80 dark:border-slate-800 shadow-sm"
        >
          <!-- 环形饼图可视化 (40% / 35% / 15% / 10%) -->
          <div
            class="md:col-span-5 flex flex-col items-center justify-center border-b md:border-b-0 md:border-r border-slate-100 dark:border-slate-800 pb-6 md:pb-0 md:pr-8"
          >
            <div class="relative w-40 h-40 md:w-44 md:h-44">
              <svg viewBox="0 0 120 120" class="w-full h-full">
                <!-- 背景灰圈 -->
                <circle
                  cx="60"
                  cy="60"
                  r="50"
                  fill="transparent"
                  stroke="#F1F5F9"
                  stroke-width="12"
                  class="dark:stroke-slate-800"></circle>

                <!-- 社区建设 (10%) - 天蓝 #38BDF8 -->
                <circle
                  cx="60"
                  cy="60"
                  r="50"
                  fill="transparent"
                  stroke="#38BDF8"
                  stroke-width="12"
                  stroke-dasharray="31.42 314.16"
                  stroke-dashoffset="-282.74"
                  transform="rotate(-90 60 60)"></circle>

                <!-- 技术学习 (15%) - 深蓝 #1D4ED8 -->
                <circle
                  cx="60"
                  cy="60"
                  r="50"
                  fill="transparent"
                  stroke="#1D4ED8"
                  stroke-width="12"
                  stroke-dasharray="47.12 314.16"
                  stroke-dashoffset="-235.62"
                  transform="rotate(-90 60 60)"></circle>

                <!-- 项目开发 (35%) - 浅蓝 #60A5FA -->
                <circle
                  cx="60"
                  cy="60"
                  r="50"
                  fill="transparent"
                  stroke="#60A5FA"
                  stroke-width="12"
                  stroke-dasharray="109.96 314.16"
                  stroke-dashoffset="-125.66"
                  transform="rotate(-90 60 60)"></circle>

                <!-- 服务器维护 (40%) - 科技蓝 #3B82F6 -->
                <circle
                  cx="60"
                  cy="60"
                  r="50"
                  fill="transparent"
                  stroke="#3B82F6"
                  stroke-width="12"
                  stroke-dasharray="125.66 314.16"
                  stroke-dashoffset="0"
                  transform="rotate(-90 60 60)"></circle>
              </svg>
              <!-- 中心文字 -->
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-[9px] uppercase font-bold tracking-widest text-slate-400">公开透明</span>
                <span class="text-base font-black text-slate-800 dark:text-slate-100">100%</span>
              </div>
            </div>
            <!-- 饼图图例 -->
            <div
              class="grid grid-cols-2 gap-x-4 gap-y-1.5 mt-5 w-full text-xs font-semibold text-slate-500 dark:text-slate-400"
            >
              <div class="flex items-center gap-1.5 justify-center">
