  <script>
    // 使用委托处理二维码点击
    function handleDonationQRClick(e: MouseEvent) {
      const qrTarget = (e.target as HTMLElement).closest('.qr-code') as HTMLElement | null;
      if (!qrTarget) return;

      const image = qrTarget.dataset.image;
      const title = qrTarget.dataset.title;
      const description = qrTarget.dataset.description;

      console.log('Donation QR clicked (delegated):', { image, title, description });

      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const showModal = (window as any).showModal;
      if (showModal) {
        showModal(image, title, description, [
          {
            href: image,
            target: '_blank',
            text: '下载二维码',
            icon: 'fas fa-download',
          },
        ]);
      }
    }

    function setupDonationQRDelegation() {
      document.removeEventListener('click', handleDonationQRClick);
      document.addEventListener('click', handleDonationQRClick);
      console.log('Donation QR delegation setup completed');
    }

    // 页面加载或切换后初始化
    setupDonationQRDelegation();
    document.addEventListener('astro:page-load', setupDonationQRDelegation);
    document.addEventListener('astro:after-swap', setupDonationQRDelegation);
  </script>
