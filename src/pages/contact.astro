---
// 启用 SSR - 每次请求时动态渲染此页面
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import Modal from '~/components/Modal.astro';
import Skeleton from '~/components/ui/Skeleton.astro';
import { Icon } from 'astro-icon/components';

// 定义类型接口
interface ContactInfo {
  title: string;
  description: string;
  info: string;
  action: string;
}

interface MediaPlatform {
  name: string;
  logo: string;
  account: string;
  accountId?: string;
  qrcode: string;
  qrcodeTitle?: string;
  qrcodeDesc?: string;
  link: string;
}

interface GroupChat {
  name: string;
  description?: string;
  limit?: string;
  groupNumber?: string;
  qrcode: string;
  joinLink: string;
}

import { fetchWithRetry } from '~/utils/utils';

// API 配置
const API_BASE_URL = 'https://api-g.lacs.cc/api/info-management';

// 获取联系方式数据
let contactInfoData: ContactInfo[] = [];
try {
  const contactResponse = await fetchWithRetry(`${API_BASE_URL}/contact-info`);
  if (contactResponse && contactResponse.ok) {
    const contactResult = await contactResponse.json();
    if (contactResult.success && contactResult.data) {
      contactInfoData = contactResult.data;
      console.log('成功获取联系方式数据，共', contactInfoData.length, '条记录');
    }
  }
} catch (error) {
  console.error('获取联系方式数据失败:', error instanceof Error ? error.message : error);
}

// 获取媒体平台数据
let mediaPlatformsData: MediaPlatform[] = [];
try {
  const mediaResponse = await fetchWithRetry(`${API_BASE_URL}/media-platforms`);
  if (mediaResponse && mediaResponse.ok) {
    const mediaResult = await mediaResponse.json();
    if (mediaResult.success && mediaResult.data) {
      mediaPlatformsData = mediaResult.data;
      console.log('成功获取媒体平台数据，共', mediaPlatformsData.length, '条记录');
    }
  }
} catch (error) {
  console.error('获取媒体平台数据失败:', error instanceof Error ? error.message : error);
}

// 获取群聊数据
let groupChatsData: GroupChat[] = [];
try {
  const groupResponse = await fetchWithRetry(`${API_BASE_URL}/group-chats`);
  if (groupResponse && groupResponse.ok) {
    const groupResult = await groupResponse.json();
    if (groupResult.success && groupResult.data) {
      groupChatsData = groupResult.data;
      console.log('成功获取群聊数据，共', groupChatsData.length, '条记录');
    }
  }
} catch (error) {
  console.error('获取群聊数据失败:', error instanceof Error ? error.message : error);
}

// 转换联系方式数据格式
const contactMethods = contactInfoData.map((contact) => {
  const isEmail = contact.title === '电子邮件';
  const isQQ = contact.title === 'QQ';
  const isWechat = contact.title === '微信';
  
  return {
    title: contact.title,
    description: contact.description,
    info: contact.info,
    action: contact.action,
    icon: isEmail
      ? 'tabler:mail'
      : isQQ
        ? 'tabler:brand-qq'
        : isWechat
          ? 'tabler:brand-wechat'
          : 'tabler:message',
    priority: isWechat
      ? '推荐首选'
      : isQQ
        ? '紧急通道'
        : '合作投稿',
    priorityClass: isWechat
      ? 'bg-blue-50 text-blue-600 dark:bg-blue-950/30 dark:text-blue-400'
      : isQQ
        ? 'bg-indigo-50 text-indigo-600 dark:bg-indigo-950/30 dark:text-indigo-400'
        : 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400',
  };
});

const metadata = {
  title: '联系我们 - 领创工作室',
  description:
    '联系领创工作室，获取技术支持、商务合作或其他服务。我们提供多种联系方式，24小时内回复您的咨询。了解我们的媒体平台和官方群聊。',
  keywords: '联系我们,技术支持,商务合作,领创工作室,客服,媒体平台,官方群聊',
};
---

<Layout metadata={metadata}>
  <CustomStyles />



  <!-- Modal Component -->
  <Modal />


  <!-- 联系我们 -->
  <section class="py-16 md:py-20 relative overflow-hidden bg-slate-50/50 dark:bg-slate-950/10" id="contact-methods">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-base text-primary dark:text-blue-200 font-bold tracking-wide uppercase mb-1">沟通渠道</p>
        <h1 class="text-3xl md:text-4xl font-black tracking-tight text-slate-900 dark:text-white mb-3">联系我们</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-10 max-w-lg mx-auto leading-relaxed">选择您喜欢的方式与我们取得联系，我们会在规定时效内为您提供答复。</p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
          {contactMethods.map((method) => (
            <div class="group p-5 md:p-6 bg-white dark:bg-slate-900/60 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-primary/50 dark:hover:border-primary/50 hover:shadow-[0_12px_30px_rgba(28,100,242,0.06)] dark:hover:shadow-[0_12px_30px_rgba(1,97,239,0.12)] transition-all duration-300 flex flex-col justify-between h-full relative overflow-hidden">
              <div>
                <div class="flex items-center justify-between mb-4">
                  <div class="w-10 h-10 rounded-xl bg-blue-50 text-primary dark:bg-blue-950/30 dark:text-blue-400 flex items-center justify-center shrink-0">
                    <Icon name={method.icon} class="w-5 h-5" />
                  </div>
                  <span class={`text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider ${method.priorityClass}`}>
                    {method.priority}
                  </span>
                </div>
                
                <h3 class="text-lg font-bold text-slate-850 dark:text-slate-100 mb-1">{method.title}</h3>
                
                <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed font-normal mb-4">
                  {method.description}
                </p>
              </div>

              <div class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-800/60">
                <div class="flex items-center justify-between gap-2 bg-slate-50 dark:bg-slate-800/40 p-2.5 rounded-xl border border-slate-100 dark:border-slate-800/80 mb-3.5">
                  <div class="truncate text-xs font-semibold text-slate-700 dark:text-slate-300">
                    <span class="text-[10px] text-slate-400 dark:text-slate-500 block font-normal leading-tight">账号/地址</span>
                    <span class="select-all font-mono">{method.info}</span>
                  </div>
                  <button 
                    class="btn-copy p-1.5 hover:bg-slate-200/50 dark:hover:bg-slate-700/50 text-slate-400 hover:text-primary rounded-lg transition-colors cursor-pointer"
                    data-text={method.info}
                    title="复制账号"
                  >
                    <Icon name="tabler:copy" class="w-4 h-4" />
                  </button>
                </div>

                <a
                  href={method.action}
                  target={method.action.startsWith('http') ? '_blank' : '_self'}
                  class="px-4 py-2 bg-primary hover:bg-primary/95 text-white text-xs font-semibold rounded-xl transition-all shadow-sm shadow-primary/10 flex items-center justify-center gap-1 cursor-pointer active:scale-[0.98]"
                >
                  立即联系
                  <Icon name="tabler:arrow-up-right" class="w-3.5 h-3.5" />
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- 媒体平台 -->
  <section id="media-platforms" class="py-16 md:py-20 relative bg-white dark:bg-slate-900/50 border-y border-slate-100 dark:border-slate-800/50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-8">
        <div class="inline-block px-3 py-1 text-xs font-semibold text-primary bg-blue-50 dark:bg-blue-950/30 rounded-full mb-3">
          媒体平台
        </div>
        <h2 class="text-3xl md:text-4xl font-black mb-3 tracking-tight text-slate-900 dark:text-white">关注我们的媒体平台</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 max-w-lg mx-auto leading-relaxed">获取最新资讯、技术分享和项目动态，多维度了解领创。</p>
      </div>

      <!-- 分类 Tab 栏 -->
      <div class="flex items-center justify-center gap-2 mb-8 overflow-x-auto pb-2 scrollbar-none max-w-md mx-auto">
        <button
          class="media-tab active px-4 py-1.5 text-xs font-semibold rounded-full bg-primary text-white transition-all cursor-pointer whitespace-nowrap active:scale-[0.97]"
          data-filter="all"
        >
          全部平台
        </button>
        <button
          class="media-tab px-4 py-1.5 text-xs font-semibold rounded-full bg-slate-50 text-slate-600 hover:bg-slate-100 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700 transition-all cursor-pointer whitespace-nowrap active:scale-[0.97]"
          data-filter="video"
        >
          视频平台
        </button>
        <button
          class="media-tab px-4 py-1.5 text-xs font-semibold rounded-full bg-slate-50 text-slate-600 hover:bg-slate-100 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700 transition-all cursor-pointer whitespace-nowrap active:scale-[0.97]"
          data-filter="tech"
        >
          技术社区
        </button>
        <button
          class="media-tab px-4 py-1.5 text-xs font-semibold rounded-full bg-slate-50 text-slate-600 hover:bg-slate-100 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700 transition-all cursor-pointer whitespace-nowrap active:scale-[0.97]"
          data-filter="social"
        >
          公众号/社群
        </button>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-5xl mx-auto">
        {
          mediaPlatformsData.length > 0 ? (
            mediaPlatformsData.map((platform) => {
              const name = platform.name || '';
              let category = 'social';
              if (name.includes('B站') || name.includes('哔哩哔哩') || name.includes('YouTube') || name.includes('视频')) {
                category = 'video';
              } else if (name.includes('CSDN') || name.includes('酷安') || name.includes('小米') || name.includes('社区') || name.includes('GitHub')) {
                category = 'tech';
              }
              const hasQrcode = !!platform.qrcode;

              return (
                <div 
                  class="media-card group relative bg-white dark:bg-slate-900/40 rounded-2xl p-4 hover:-translate-y-1 hover:shadow-[0_12px_30px_rgba(0,0,0,0.04)] dark:hover:shadow-[0_12px_30px_rgba(0,0,0,0.15)] transition-all duration-300 flex flex-col justify-between h-full border border-slate-200 dark:border-slate-800 hover:border-primary/50 dark:hover:border-primary/50"
                  data-category={category}
                >
                  <div class="flex items-center text-left relative z-10 mb-4">
                    <div class="w-12 h-12 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center shrink-0 border border-slate-100 dark:border-slate-800 overflow-hidden shadow-sm">
                      <img
                        src={platform.logo}
                        alt={platform.name}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    </div>
                    <div class="ml-3 flex-grow min-w-0">
                      <div class="flex items-center gap-1.5 justify-start">
                        <h3 class="text-xs md:text-sm font-bold text-slate-800 dark:text-white truncate">
                          {platform.name}
                        </h3>
                        {hasQrcode && (
                          <button
                            class="qr-button p-1 text-slate-400 hover:text-primary rounded-lg border border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800 shrink-0 cursor-pointer"
                            data-qrcode={platform.qrcode}
                            data-title={platform.qrcodeTitle || platform.name}
                            data-description={platform.qrcodeDesc || '扫码关注官方账号'}
                            data-link={platform.link}
                            title="显示二维码"
                          >
                            <Icon name="tabler:qrcode" class="w-3.5 h-3.5" />
                          </button>
                        )}
                      </div>
                      <p class="text-[9px] md:text-xs font-semibold text-slate-500 dark:text-slate-400 select-all font-mono mt-0.5 truncate">
                        @{platform.account}
                      </p>
                    </div>
                  </div>

                  <div class="mt-auto pt-3 border-t border-slate-100 dark:border-slate-800/60 w-full relative z-10">
                    <a
                      href={platform.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="px-3 py-1.5 bg-primary hover:bg-primary/95 text-white text-[11px] md:text-xs font-semibold rounded-lg transition-all shadow-sm shadow-primary/10 flex items-center justify-center gap-1 cursor-pointer active:scale-[0.98] w-full"
                    >
                      访问主页
                      <Icon name="tabler:arrow-up-right" class="w-3 h-3" />
                    </a>
                  </div>
                </div>
              )
            })
          ) : (
            Array.from({ length: 4 }).map(() => (
              <div class="bg-white dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 rounded-2xl p-4 flex flex-col justify-between h-full animate-pulse">
                <div class="flex items-center w-full mb-4 text-left">
                  <Skeleton class="w-12 h-12 rounded-xl shrink-0" />
                  <div class="ml-3 flex-grow w-full space-y-1.5">
                    <Skeleton class="h-4 w-20" />
                    <Skeleton class="h-3 w-28" />
                  </div>
                </div>
                <div class="w-full pt-3 border-t border-slate-100 dark:border-slate-800/60">
                  <Skeleton class="h-8 rounded-lg w-full" />
                </div>
              </div>
            ))
          )
        }
      </div>
    </div>
  </section>

  <!-- QQ群聊 -->
  <section class="py-16 md:py-20 relative overflow-hidden bg-slate-50/50 dark:bg-slate-950/10 border-b border-slate-100 dark:border-slate-800/50" id="qun-group">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-8">
        <div class="inline-block px-3 py-1 text-xs font-semibold text-primary bg-blue-50 dark:bg-blue-950/30 rounded-full mb-3">
          官方社区
        </div>
        <h2 class="text-3xl md:text-4xl font-black mb-3 tracking-tight text-slate-900 dark:text-white">加入我们的社区</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 max-w-lg mx-auto leading-relaxed">与其他用户交流，获取最新资讯、官方公告和即时技术支持。</p>
      </div>

      <!-- 安全防骗提示 -->
      <div class="max-w-3xl mx-auto mb-8 bg-blue-50/50 dark:bg-blue-950/20 border border-blue-100 dark:border-blue-900/50 rounded-2xl p-4 flex gap-3 text-left items-start select-none">
        <Icon name="tabler:shield" class="w-5 h-5 text-blue-600 dark:text-blue-400 shrink-0 mt-0.5" />
        <div class="text-xs text-blue-700 dark:text-blue-300 leading-relaxed font-normal">
          <strong class="font-bold">安全防骗提示：</strong>官方客服及群管理员不会以任何理由向您索取账户密码，更不会主动发起私下涉及金钱交易。请认准官方QQ号和群号，防范欺诈。
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {
          groupChatsData.map((group) => {
            const name = group.name || '';
            let iconName = 'tabler:brand-qq';
            let iconBg = 'bg-blue-50 text-blue-600 dark:bg-blue-950/30 dark:text-blue-400';
            let usageDesc = '官方合规交流群';
            let statusText = '推荐加入';
            let statusClass = 'bg-blue-50 text-blue-600 dark:bg-blue-950/30 dark:text-blue-400';
            
            if (name.includes('总群') || name.includes('官方群')) {
              iconName = 'tabler:users-group';
              iconBg = 'bg-blue-50 text-blue-600 dark:bg-blue-950/30 dark:text-blue-400';
              usageDesc = '日常综合交流，获取最新资源与官方通告的第一入口。';
              statusText = '推荐首选';
              statusClass = 'bg-blue-50 text-blue-600 dark:bg-blue-950/30 dark:text-blue-400';
            } else if (name.includes('工具箱') || name.includes('开发') || name.includes('技术') || name.includes('反馈')) {
              iconName = 'tabler:terminal';
              iconBg = 'bg-indigo-50 text-indigo-600 dark:bg-indigo-950/30 dark:text-indigo-400';
              usageDesc = '针对领创开发者工具箱及其他开源项目的专项技术反馈与解答。';
              statusText = '专项支持';
              statusClass = 'bg-indigo-50 text-indigo-600 dark:bg-indigo-950/30 dark:text-indigo-400';
            } else if (name.includes('分群') || name.includes('交流') || name.includes('备用')) {
              iconName = 'tabler:messages';
              iconBg = 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400';
              usageDesc = '社区分流交流群，适合日常唠嗑与技术吹水。';
              statusText = '流畅加入';
              statusClass = 'bg-slate-100 text-slate-600 dark:bg-slate-900 dark:text-slate-400';
            } else if (name.includes('频道') || name.includes('Channel') || name.includes('论坛')) {
              iconName = 'tabler:antenna';
              iconBg = 'bg-purple-50 text-purple-600 dark:bg-purple-950/30 dark:text-purple-400';
              usageDesc = '领创官方论坛频道，适合沉淀高质量技术交流与讨论。';
              statusText = '公开中';
              statusClass = 'bg-purple-50 text-purple-600 dark:bg-purple-950/30 dark:text-purple-400';
            }

            return (
              <div 
                class="group relative bg-white dark:bg-slate-900/40 rounded-2xl p-5 md:p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_30px_rgba(0,0,0,0.04)] dark:hover:shadow-[0_12px_30px_rgba(0,0,0,0.15)] flex flex-col justify-between h-full border border-slate-200 dark:border-slate-800 hover:border-primary/50 dark:hover:border-primary/50"
              >
                <div class="flex items-start text-left relative z-10 mb-4 gap-4">
                  <!-- 非对称图标容器 -->
                  <div class={`w-12 h-12 rounded-xl flex items-center justify-center shrink-0 border border-slate-100 dark:border-slate-800 shadow-sm ${iconBg}`}>
                    <Icon name={iconName} class="w-6 h-6" />
                  </div>
                  <div class="flex-grow min-w-0">
                    <div class="flex items-center justify-between gap-2 mb-1">
                      <h3 class="text-sm md:text-base font-bold text-slate-800 dark:text-white truncate">{group.name}</h3>
                      
                      <!-- 右上角小卡片操作 -->
                      <div class="flex items-center gap-1.5 shrink-0 select-none">
                        <span class={`text-[9px] font-bold px-2 py-0.5 rounded-full tracking-wider ${statusClass}`}>
                          {statusText}
                        </span>
                        <button
                          class="p-1 text-slate-400 hover:text-primary rounded-lg border border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800 shrink-0 cursor-pointer"
                          onclick={`showModal('${group.qrcode}', '${group.name}', '扫码加入群聊', [{text: '直接加入', href: '${group.joinLink}', target: '_blank', icon: 'fas fa-user-plus'}])`}
                          title="查看二维码"
                        >
                          <Icon name="tabler:qrcode" class="w-3.5 h-3.5" />
                        </button>
                      </div>
                    </div>
                    
                    <div class="flex flex-col gap-1.5">
                      {group.groupNumber && (
                        <div class="flex items-center gap-1">
                          <span class="text-[9px] text-slate-400 dark:text-slate-500 font-normal">群号:</span>
                          <span class="text-[10px] md:text-xs font-semibold text-slate-650 dark:text-slate-350 select-all font-mono">{group.groupNumber}</span>
                          <button 
                            class="btn-copy p-1 text-slate-400 hover:text-primary rounded transition-colors cursor-pointer"
                            data-text={group.groupNumber}
                            title="复制群号"
                          >
                            <Icon name="tabler:copy" class="w-3 h-3" />
                          </button>
                        </div>
                      )}
                      <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed font-normal">{usageDesc}</p>
                    </div>
                  </div>
                </div>

                <div class="mt-auto pt-3 border-t border-slate-100 dark:border-slate-800/60 w-full relative z-10">
                  <a
                    href={group.joinLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="px-4 py-2 bg-primary hover:bg-primary/95 text-white text-xs font-semibold rounded-xl transition-all shadow-sm shadow-primary/10 flex items-center justify-center gap-1.5 cursor-pointer active:scale-[0.98] w-full"
                  >
                    一键加入群聊
                    <Icon name="tabler:user-plus" class="w-3.5 h-3.5" />
                  </a>
                </div>
              </div>
            )
          })
        }
      </div>
    </div>
  </section>

  <!-- 服务时间和说明 -->
  <section class="py-16 md:py-20 bg-slate-50/50 dark:bg-slate-900/20 border-y border-slate-150 dark:border-slate-800/80" id="service-instructions">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-base text-primary dark:text-blue-200 font-bold tracking-wide uppercase">服务说明</p>
          <h2 class="text-3xl md:text-4xl font-black tracking-tight text-slate-900 dark:text-white mt-1">服务时间与政策说明</h2>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-3 font-normal">了解我们的工作时间，确保能获得即时而高效的技术答复。</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
          <!-- 响应时间 -->
          <div class="group bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 md:p-6 hover:shadow-sm hover:border-primary/40 transition-all duration-300">
