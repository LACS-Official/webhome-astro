  <!-- 二维码与交互逻辑处理 -->
  <script>
    // 提示框逻辑
    function showToast(message) {
      const toast = document.createElement('div');
      toast.className = 'fixed bottom-5 left-1/2 transform -translate-x-1/2 px-4 py-2 bg-slate-900/90 dark:bg-white/95 text-white dark:text-slate-900 text-xs font-semibold rounded-xl shadow-lg z-50 transition-all duration-300 opacity-0 translate-y-2 select-none pointer-events-none flex items-center gap-1.5 border border-slate-800/10 dark:border-white/10';
      toast.innerHTML = `<svg class="w-3.5 h-3.5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>${message}`;
      document.body.appendChild(toast);
      
      // 触发重绘以执行动画
      toast.offsetHeight;
      
      toast.classList.remove('opacity-0', 'translate-y-2');
      toast.classList.add('opacity-100', 'translate-y-0');
      
      setTimeout(() => {
        toast.classList.remove('opacity-100', 'translate-y-0');
        toast.classList.add('opacity-0', 'translate-y-2');
        setTimeout(() => {
          toast.remove();
        }, 300);
      }, 2000);
    }

    // 复制操作处理
    function handleCopyClick(e) {
      const button = e.target.closest('.btn-copy');
      if (!button) return;
      
      e.preventDefault();
      const text = button.dataset.text;
      if (!text) return;
      
      navigator.clipboard.writeText(text).then(() => {
        showToast('已成功复制账号/号码');
      }).catch(err => {
        console.error('复制失败:', err);
        showToast('复制失败，请手动选择复制');
      });
    }

    // 媒体类别过滤处理
    function handleTabClick(e) {
      const tab = e.target.closest('.media-tab') as HTMLElement | null;
      if (!tab) return;
      
      e.preventDefault();
      const tabs = document.querySelectorAll('.media-tab');
      const cards = document.querySelectorAll('.media-card');
      
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-primary', 'text-white');
        t.classList.add('bg-slate-50', 'text-slate-600', 'dark:bg-slate-800', 'dark:text-slate-300');
      });
      
      tab.classList.remove('bg-slate-50', 'text-slate-600', 'dark:bg-slate-800', 'dark:text-slate-300');
      tab.classList.add('active', 'bg-primary', 'text-white');
      
      const filter = tab.getAttribute('data-filter');
      cards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        if (filter === 'all' || cardCategory === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    }

    // 二维码按钮处理
    function handleQRClick(e) {
      const button = e.target.closest('.qr-button');
      if (!button) return;

      e.preventDefault();
      const qrcode = button.dataset.qrcode;
      const title = button.dataset.title;
      const description = button.dataset.description;
      const link = button.dataset.link;

      console.log('QR button clicked (delegated):', { qrcode, title, description, link });
      
      // 使用增强版弹窗显示二维码
      if (window.showModal) {
        window.showModal(qrcode, title, description, [
          {
            text: '访问链接',
            href: link,
            target: '_blank',
            icon: 'fas fa-external-link-alt',
          },
        ]);
      }
    }

    function setupInteractivity() {
      // 移除旧的监听器并添加新的 (防多次绑定)
      document.removeEventListener('click', handleQRClick);
      document.removeEventListener('click', handleCopyClick);
      document.removeEventListener('click', handleTabClick);
      
      document.addEventListener('click', handleQRClick);
      document.addEventListener('click', handleCopyClick);
      document.addEventListener('click', handleTabClick);
      
      console.log('Interactivity delegation setup completed');
    }

    // 页面加载或切换后初始化
    setupInteractivity();
    
    document.addEventListener('astro:page-load', setupInteractivity);
    document.addEventListener('astro:after-swap', setupInteractivity);
  </script>
</Layout>
